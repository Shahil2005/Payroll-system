# App configuration
DEBUG=True
APP_ENV=development

# Auth / JWT
# REQUIRED in production (APP_ENV=production refuses to boot with the dev default).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=<your_secret_key>

# CORS: comma-separated list of allowed browser origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database configuration
DB_NAME=<your_database_name>
DB_USER=<your_username>
DB_PASSWORD=<your_password>
DB_PORT=<your_port>
DB_HOST=localhost
# Log every SQL statement (verbose; local debugging only).
SQL_ECHO=false

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<redis_password>

# Email (Resend) — https://resend.com
# Required to enable payslip email. The from-email's domain must be verified
# in your Resend account (use onboarding@resend.dev for quick testing).
RESEND_API_KEY=<your_resend_api_key>
RESEND_FROM_EMAIL=<verified_sender@yourdomain.com>
RESEND_FROM_NAME=Croar Payroll
